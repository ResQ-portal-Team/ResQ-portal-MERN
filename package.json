{
  "name": "resq-portal-mern",
  "version": "1.0.0",
  "description": "ResQ Portal - MERN Stack",
  "main": "server.js",
  "scripts": {
    "start": "node backend/server.js",
    "backend": "cd backend && npm run dev",
    "frontend": "cd frontend && npm start",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "seed:community": "node backend/scripts/seedCommunityEvents.js",
    "seed:lostfound": "node backend/scripts/seedLostFoundItems.js"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14"
  },
  "dependencies": {
    "@google/generative-ai": "^0.3.0",
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.2",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.3",
    "multer": "^2.1.1"
  }
}
